{
  "name": "theglobe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "verify:data": "node scripts/verify-boundary-data.mjs && node scripts/verify-city-data.mjs",
    "smoke:korea": "npm run build && node scripts/smoke-korea-family-map.mjs",
    "verify": "npm run typecheck && npm run verify:data && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "verify:city-data": "node scripts/verify-city-data.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "three": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/three": "latest",
    "typescript": "latest"
  }
}
